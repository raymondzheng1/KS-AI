# ── KidSmart AI Training — environment variables ─────────────────────────
# Copy to .env.local for local dev. Real secrets live in the Vercel dashboard,
# NEVER committed. Local dev runs without any of these (in-memory KV fallback).

# Upstash Redis (Vercel Marketplace injects the KV_* pair; legacy = UPSTASH_*).
# Required in production — without it, route handlers throw and the rate
# limiter fails closed (Harness §6.4).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Shared passcode that unlocks facilitator mode (?mode=facilitator).
# Keep answer keys away from students. Server-only.
FACILITATOR_PASSCODE=

# Bearer secret guarding cron endpoints (e.g. /api/cron/backup). Server-only.
CRON_SECRET=

# Bearer token guarding the /api/export snapshot endpoint. Server-only.
EXPORT_TOKEN=

# Off-store daily backup (optional). When both are set, /api/cron/backup commits
# a dated KV snapshot to the repo so it survives losing the KV provider.
GITHUB_TOKEN=
GITHUB_REPO=

# Contact form (optional). When RESEND_API_KEY is unset, /api/contact returns a
# friendly 503. RESEND_FROM defaults to onboarding@resend.dev (only delivers to
# the Resend account owner) — set a verified-domain sender for production.
# CONTACT_TO is where contact messages are delivered (defaults to the admin inbox).
# NOTE: changing any env var requires a REDEPLOY to take effect.
RESEND_API_KEY=
RESEND_FROM=
CONTACT_TO=

# Google Analytics 4 (optional, dormant until set). When unset, zero 3rd-party
# calls. Never set on /p/<code> or /room/<id> pages (no PII to GA).
NEXT_PUBLIC_GA_ID=

# Canonical site origin for sitemap / robots / canonical URLs (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://kidsmart-ai-training.vercel.app
